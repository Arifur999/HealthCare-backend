<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>OTP Verification</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #f2f6fb;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: #1f2937;
    }

    table {
      border-spacing: 0;
      border-collapse: collapse;
    }

    .container {
      width: 100%;
      padding: 28px 12px;
      background-color: #f2f6fb;
    }

    .card {
      width: 100%;
      max-width: 620px;
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 8px 22px rgba(15, 23, 42, 0.08);
    }

    .header {
      padding: 28px 32px;
      background: linear-gradient(135deg, #0d4b86 0%, #0d9488 100%);
      color: #ffffff;
    }

    .header h1 {
      margin: 0;
      font-size: 24px;
      line-height: 1.3;
      font-weight: 700;
    }

    .header p {
      margin: 8px 0 0;
      font-size: 14px;
      opacity: 0.95;
    }

    .content {
      padding: 30px 32px;
    }

    .content h2 {
      margin: 0 0 14px;
      font-size: 22px;
      line-height: 1.35;
      color: #0f172a;
    }

    .content p {
      margin: 0 0 14px;
      font-size: 15px;
      line-height: 1.7;
      color: #334155;
    }

    .otp-wrap {
      margin: 20px 0 18px;
      padding: 16px;
      border: 1px dashed #14b8a6;
      border-radius: 10px;
      background-color: #ecfeff;
      text-align: center;
    }

    .otp-code {
      display: inline-block;
      letter-spacing: 8px;
      font-size: 32px;
      line-height: 1;
      font-weight: 700;
      color: #0f766e;
      font-family: "Courier New", Courier, monospace;
    }

    .notice {
      margin-top: 6px;
      font-size: 13px;
      color: #475569;
    }

    .footer {
      padding: 18px 32px 26px;
      border-top: 1px solid #e2e8f0;
      font-size: 12px;
      line-height: 1.6;
      color: #64748b;
      background-color: #f8fafc;
    }

    @media only screen and (max-width: 620px) {
      .header,
      .content,
      .footer {
        padding-left: 20px !important;
        padding-right: 20px !important;
      }

      .header h1 {
        font-size: 21px !important;
      }

      .content h2 {
        font-size: 20px !important;
      }

      .otp-code {
        font-size: 28px !important;
        letter-spacing: 6px !important;
      }
    }
  </style>
</head>
<body>
  <table role="presentation" width="100%" class="container">
    <tr>
      <td align="center">
        <table role="presentation" class="card">
          <tr>
            <td class="header">
              <h1>HealthCare Verification</h1>
              <p>Secure one-time password for your account access</p>
            </td>
          </tr>
          <tr>
            <td class="content">
              <h2>Hello <%= name %>,</h2>
              <p>Use the OTP below to verify your email and continue securely.</p>

              <div class="otp-wrap">
                <span class="otp-code"><%= otp %></span>
                <div class="notice">This code expires in 2 minutes.</div>
              </div>

              <p>If you did not request this code, please ignore this email.</p>
              <p>For your security, do not share this OTP with anyone.</p>
            </td>
          </tr>
          <tr>
            <td class="footer">
              This is an automated email from HealthCare. Please do not reply to this message.
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
>