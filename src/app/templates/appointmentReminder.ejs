<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Appointment Reminder</title>
  <style>
    body { margin: 0; padding: 0; background-color: #f2f6fb; font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif; color: #1f2937; }
    .container { width: 100%; padding: 28px 12px; background-color: #f2f6fb; }
    .card { width: 100%; max-width: 600px; margin: 0 auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 6px 24px rgba(31, 43, 108, 0.08); }
    .header { background: #1f2b6c; padding: 28px 32px; color: #ffffff; }
    .brand { font-size: 24px; font-weight: 700; letter-spacing: 1px; }
    .brand .accent { color: #159eec; }
    .body { padding: 32px; }
    .h1 { font-size: 20px; margin: 0 0 8px; color: #1f2b6c; }
    .muted { color: #5b6472; font-size: 14px; line-height: 1.6; }
    .detail { margin: 20px 0; border: 1px solid #e4e9f5; border-radius: 10px; overflow: hidden; }
    .detail-row { display: flex; justify-content: space-between; padding: 12px 16px; border-bottom: 1px solid #eef2fb; font-size: 14px; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { color: #5b6472; }
    .detail-value { font-weight: 600; color: #1f2b6c; }
    .btn { display: inline-block; margin-top: 8px; background: #159eec; color: #ffffff; text-decoration: none; padding: 12px 24px; border-radius: 999px; font-weight: 600; font-size: 14px; }
    .footer { padding: 20px 32px; color: #94a3b8; font-size: 12px; text-align: center; }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="header">
        <div class="brand">MED<span class="accent">DICAL</span></div>
      </div>
      <div class="body">
        <h1 class="h1">Your appointment is coming up</h1>
        <p class="muted">Hi <%= patientName %>, this is a friendly reminder that your appointment starts soon.</p>

        <div class="detail">
          <div class="detail-row"><span class="detail-label">Doctor</span><span class="detail-value"><%= doctorName %></span></div>
          <div class="detail-row"><span class="detail-label">Starts</span><span class="detail-value"><%= startTime %></span></div>
          <div class="detail-row"><span class="detail-label">Type</span><span class="detail-value"><%= appointmentType %></span></div>
        </div>

        <% if (joinLink) { %>
          <p class="muted">This is a video consultation. Join using the button below at your scheduled time:</p>
          <a class="btn" href="<%= joinLink %>">Join Video Call</a>
        <% } else { %>
          <p class="muted">Please arrive a few minutes early for your in-person visit.</p>
        <% } %>
      </div>
      <div class="footer">
        This is an automated reminder from MEDdical. Please do not reply to this email.
      </div>
    </div>
  </div>
</body>
</html>
