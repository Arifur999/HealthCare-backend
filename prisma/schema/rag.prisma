model DocumentEmbedding{
    id          String   @id @default(cuid())
    chunkKey   String @unique
    sourceType  String
    sourceId    String
    sourceLabel String?
    content     String
    metadata    Json?

    embedding   Unsupported("vector()")

    isDeleted   Boolean  @default(false)
    deletedAt   DateTime?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

   

}