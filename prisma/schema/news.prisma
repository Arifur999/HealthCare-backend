model News {
  id          String   @id @default(uuid(7))
  title       String
  slug        String   @unique
  excerpt     String
  content     String[]
  coverImage  String?
  author      String   @default("Care Team")
  category    String   @default("Health Care")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
  @@map("news")
}
