NODE_ENV=production
PORT=5000

# Postgres connection string. Must point to a database with the pgvector
# extension available (used by the RAG module). Supabase and Neon both
# support "create extension vector".
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis connection string. Use a rediss:// URL for TLS providers (e.g. Upstash).
REDIS_URL=rediss://default:password@host:6379

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me

BETTER_AUTH_SECRET=generate-a-long-random-string
BETTER_AUTH_URL=https://your-backend-domain.example.com
ACCESS_TOKEN_SECRET=generate-a-long-random-string
REFRESH_TOKEN_SECRET=generate-a-long-random-string
ACCESS_TOKEN_EXPIRATION=1d
REFRESH_TOKEN_EXPIRATION=7d
BETTER_AUTH_SESSION_EXPIRATION=7d
BETTER_AUTH_SESSION_TOKEN_UPDATE_AGE=1d

EMAIL_SENDER_SMTP_USER=
EMAIL_SENDER_SMTP_PASS=
EMAIL_SENDER_SMTP_HOST=
EMAIL_SENDER_SMTP_PORT=
EMAIL_SENDER_SMTP_FROM=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-frontend-domain.example.com/api/auth/callback/google
FRONTEND_URL=https://your-frontend-domain.example.com

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

OPENROUTER_API_KEY=
OPENROUTER_EMBEDDINGS_MODEL=
OPENROUTER_LLM_MODEL=
